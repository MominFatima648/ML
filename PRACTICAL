BACK PROPOGATION
# Import required libraries
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.model_selection import train_test_split
from sklearn.neural_network import MLPClassifier
from sklearn.metrics import accuracy_score

# Step 1: Define finite word dataset
words = ["good", "excellent", "happy", "nice",
         "bad", "terrible", "sad", "poor"]

labels = ["positive", "positive", "positive", "positive",
          "negative", "negative", "negative", "negative"]

# Step 2: Convert words to numeric features
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(words)
y = labels

# Step 3: Split dataset into training and testing
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3)

# Step 4: Create Neural Network using Backpropagation
model = MLPClassifier(hidden_layer_sizes=(5),
                      max_iter=1000,
                      learning_rate_init=0.01)

# Step 5: Train the model
model.fit(X_train, y_train)

# Step 6: Predict on test data
predictions = model.predict(X_test)

# Step 7: Evaluate performance
print("Accuracy:", accuracy_score(y_test, predictions))

# Step 8: Predict custom word
test_word = [input("Enter a word to classify: ")]
test_vector = vectorizer.transform(test_word)
prediction = model.predict(test_vector)

print("The word is classified as:", prediction[0])



